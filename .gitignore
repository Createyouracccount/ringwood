# ──────── secrets (NEVER commit) ────────
.env
.env.*
!.env.example
*.key
*.pem

# ──────── Python ────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ruff_cache/
.venv/
venv/
dist/
build/

# ──────── Node ────────
node_modules/
npm-debug.log*
.pnpm-debug.log*
.yarn/

# ──────── wiki runtime artifacts ────────
# The wiki/ markdown is meant to be committed; the derived index is not.
.index/
wiki-data/
*.sqlite*
*.db-journal

# ──────── live test outputs ────────
# A/B run results contain team facts; regenerated on every run.
packages/ringwood/tests_live/quality_run.json
packages/ringwood/tests_live/*_run.json

# macOS / editor
.DS_Store
.idea/
.vscode/
*.swp

# ──────── internal-only design docs ────────
# Kept locally for reference, never published.
PLAN.md
docs/_local/
