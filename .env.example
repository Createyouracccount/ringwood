# llm-wiki — environment template
# ─────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` in one of these locations:
#
#   <wiki_root>/.env              per-wiki  (recommended for most users)
#   <cwd>/.env                    per-project
#   ~/.config/llm-wiki/.env       user-wide fallback
#
# Precedence (highest first):
#   1. real environment variables (never overridden)
#   2. <wiki_root>/.env
#   3. <cwd>/.env
#   4. ~/.config/llm-wiki/.env
#
# NEVER commit a real `.env` file. `.gitignore` already excludes it.
# ─────────────────────────────────────────────────────────────────────────

# Anthropic API key. Without this, the engine runs in offline-stub mode:
# rule-based classifier + regex decision, no Claude calls. Saves still work,
# but quality is far lower. Get yours at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# Optional model overrides. Defaults are sensible — change only if you know
# why. Use alias form (no date stamp) unless you need to pin a revision.
# WIKI_HAIKU_MODEL=claude-haiku-4-5
# WIKI_SONNET_MODEL=claude-sonnet-4-6

# Minimum system-prompt length (in characters) before the engine attaches a
# cache_control marker. Below this threshold, prompt caching costs more than
# it saves. Default 16000 ≈ 4096 tokens, Haiku 4.5 floor.
# WIKI_MIN_CACHEABLE_CHARS=16000

# Force a specific LLM backend: "anthropic" | "stub". Default picks anthropic
# if ANTHROPIC_API_KEY is set, stub otherwise.
# WIKI_LLM_PROVIDER=anthropic

# Wiki root directory (tools fall back to ~/llm-wiki if unset).
# WIKI_ROOT=~/llm-wiki

# ─────────────────────────────────────────────────────────────────────────
# Future (Phase 5):
# COHERE_API_KEY=...     # rerank
# VOYAGE_API_KEY=...     # embeddings
